# Copy this file to .env and fill in your actual values
# Never commit your real .env file to version control

# Local MongoDB
# MONGODB_URI=mongodb://localhost:27017/games

# Production — Azure Cosmos DB (replace with your actual connection string)
MONGODB_URI=mongodb://<account>:<primary-key>@<account>.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@<account>@

JWT_SECRET=your_jwt_secret_here
PORT=5000
